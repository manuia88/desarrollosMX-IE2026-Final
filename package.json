{
  "name": "desarrollosmx",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:phase-09": "playwright test tests/e2e/fase-09-n1-scores.spec.ts",
    "test:a11y": "playwright test tests/e2e/a11y.spec.ts",
    "format": "biome format --write .",
    "db:types": "supabase gen types typescript --project-id qxfuqwlktmhokwwlvggy > shared/types/database.ts",
    "db:push": "supabase db push",
    "db:reset": "supabase db reset",
    "i18n:validate": "node scripts/validate-i18n.mjs",
    "audit:rls": "node scripts/audit-rls.mjs",
    "audit:selects": "node scripts/grep-unsafe-selects.mjs",
    "audit:e2e": "node scripts/audit-dead-ui.mjs",
    "audit:e2e:ci": "node scripts/audit-dead-ui.mjs --ci --json",
    "audit:habi": "node scripts/audit-forbidden-habi.mjs",
    "registry:snapshot": "node --experimental-strip-types scripts/registry-snapshot.mjs",
    "cascades:export": "node --experimental-strip-types scripts/cascades-export.mjs",
    "scores:lineage-export": "node --experimental-strip-types scripts/scores-lineage-export.mjs",
    "test:security": "vitest run tests/security --passWithNoTests",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.71",
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/react": "^3.0.170",
    "@hookform/resolvers": "^5.2.2",
    "@opentelemetry/api": "^1.9.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.3",
    "@tanstack/react-query": "^5.99.0",
    "@trpc/client": "^11.16.0",
    "@trpc/react-query": "^11.16.0",
    "@trpc/server": "^11.16.0",
    "@vercel/otel": "^2.1.2",
    "ai": "^6.0.168",
    "botid": "^1.5.11",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "framer-motion": "^12.38.0",
    "h3-js": "^4.4.0",
    "next": "^16.2.4",
    "next-intl": "^4.9.1",
    "next-themes": "^0.4.6",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.5",
    "react-hook-form": "^7.72.1",
    "react-hotkeys-hook": "^5.2.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@axe-core/react": "^4.11.2",
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "@swc/helpers": "^0.5.21",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/parser": "^8.58.2",
    "@typescript-eslint/visitor-keys": "^8.58.2",
    "@vitejs/plugin-react": "^6.0.1",
    "fast-glob": "^3.3.3",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "picocolors": "^1.1.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react-dom": "^19.2.5",
    "supabase": "^2.92.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
